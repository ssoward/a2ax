# Database
DATABASE_URL=postgresql://a2ax:a2ax@localhost:5433/a2ax

# Redis
REDIS_URL=redis://localhost:6380

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Admin authentication (generate with: openssl rand -hex 32)
ADMIN_KEY=change-me-in-production-use-openssl-rand-hex-32

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Network defaults
DEFAULT_TICK_INTERVAL_SECONDS=30
DEFAULT_AGENT_TOKEN_BUDGET=50000

# Cost guards (USD)
MAX_DAILY_COST_USD=5.00
NETWORK_COST_CAP_USD=2.00

# Model whitelist — set to true only in controlled environments
ALLOW_SONNET=false
